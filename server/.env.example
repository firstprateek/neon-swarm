# NEON SWARM backend — copy to .env and fill in.

# Long random shared secret the Cloudflare Tunnel injects as `x-tunnel-secret` on
# every request, so the origin rejects anything not coming through the tunnel.
#   generate: openssl rand -hex 32
TUNNEL_SECRET=change-me-to-a-long-random-string

# Directory holding the daily-rotating salt. Put it on a RAM disk so the salt never
# touches persistent storage (then yesterday's anon hashes are truly irreversible).
#   macOS RAM disk: diskutil erasevolume APFS ramsalt $(hdiutil attach -nomount ram://32768)
SALT_DIR=/Volumes/ramsalt
